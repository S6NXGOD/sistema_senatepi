{
  "name": "@senatepi/api",
  "version": "0.1.0",
  "private": true,
  "description": "API NestJS do SENATEPI",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "prisma migrate deploy && node dist/main.js",
