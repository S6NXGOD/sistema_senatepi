# ==========================================================================
# SENATEPI — variáveis de ambiente (copie para .env e preencha)
# NUNCA faça commit do .env preenchido. No Railway, defina estas variáveis
# no painel de cada serviço (nada de segredos no repositório).
# ==========================================================================

# ┌────────────────────────────────────────────────────────────────────────┐
# │ SERVIÇO API (NestJS) — apps/api                                        │
# └────────────────────────────────────────────────────────────────────────┘

# ---- Banco de dados (PostgreSQL) ----
# No Railway, use a referência do plugin Postgres: ${{ Postgres.DATABASE_URL }}
DATABASE_URL=

# ---- Autenticação (JWT) ----
# Gere segredos fortes e ÚNICOS em produção: openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_ACCESS_EXPIRES_IN=30d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=60d

# Segredo para assinar os tokens dos QR Codes (HMAC) — gere um valor forte.
QR_SIGNING_SECRET=

# ---- Usuário administrador padrão (criado só no PRIMEIRO deploy) ----
SEED_ADMIN_EMAIL=admin@senatepi.org.br
# Defina uma senha forte ANTES do primeiro deploy. Se vazio, usa um padrão inseguro.
SEED_ADMIN_PASSWORD=

# ---- Armazenamento de arquivos ----
# Driver: "local" (grava em disco e serve pela API) ou "s3" (MinIO/AWS)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# URL pública onde a API serve os uploads (ex.: https://sua-api.up.railway.app)
STORAGE_PUBLIC_URL=
# Abaixo: usados apenas quando STORAGE_DRIVER=s3
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=senatepi
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_FORCE_PATH_STYLE=true

# ---- API ----
ASSETS_DIR=./assets
# O Railway injeta PORT automaticamente; API_PORT é o fallback local.
API_PORT=3333
API_PREFIX=api
NODE_ENV=production
# Origens permitidas para CORS (separadas por vírgula) — inclua o domínio do front.
CORS_ORIGINS=http://localhost:3000
# Habilita a doc Swagger em /api/docs (desligada por padrão em produção).
SWAGGER_ENABLED=false

# ┌────────────────────────────────────────────────────────────────────────┐
# │ SERVIÇO WEB (Next.js) — apps/web                                        │
# │ NEXT_PUBLIC_* são embutidas no BUILD: defina-as no build do serviço web │
# └────────────────────────────────────────────────────────────────────────┘

# URL pública da API (ex.: https://sua-api.up.railway.app/api)
NEXT_PUBLIC_API_URL=http://localhost:3333/api
NEXT_PUBLIC_APP_NAME=SENATEPI
